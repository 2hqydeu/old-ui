local function GetGunDropCFrame(gunDrop)
	if gunDrop:IsA("BasePart") then
		return gunDrop.CFrame
	elseif gunDrop:IsA("Model") then
		local part = gunDrop.PrimaryPart or gunDrop:FindFirstChildWhichIsA("BasePart", true)
		return part and part.CFrame or nil
	end
	return nil
end

local function GetGunDropTouchPart(gunDrop)
	if not gunDrop then return nil end
	if gunDrop:IsA("BasePart") then return gunDrop end
	if gunDrop:IsA("Model") then
		return gunDrop.PrimaryPart or gunDrop:FindFirstChildWhichIsA("BasePart", true)
	end
	return nil
end

local function GetTopLevelWorkspaceObject(instance)
	local current = instance
	while current and current.Parent and current.Parent ~= workspace do
		current = current.Parent
	end
	return current
end

local function IsAliveAndInsideActiveMap(gunDrop)
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or humanoid.Health <= 0 or not root then return false end

	local map = GetTopLevelWorkspaceObject(gunDrop)
	if not map or map.Parent ~= workspace then return false end

	if map:IsA("Model") then
		local mapCFrame, mapSize = map:GetBoundingBox()
		local localPosition = mapCFrame:PointToObjectSpace(root.Position)
		local padding = Vector3.new(20, 20, 20)
		local halfSize = (mapSize / 2) + padding
		return math.abs(localPosition.X) <= halfSize.X
			and math.abs(localPosition.Y) <= halfSize.Y
			and math.abs(localPosition.Z) <= halfSize.Z
	end

	return true
end

function HubState.IsGunPickupSafe(gunPosition)
	if ThemeObjects.RefreshMM2RolesFromTools then ThemeObjects.RefreshMM2RolesFromTools() end
	local murderer = HubState.CurrentMurderer
	if not murderer or murderer == Player then return true end
	local murdererCharacter = murderer.Character
	local murdererHumanoid = murdererCharacter and murdererCharacter:FindFirstChildOfClass("Humanoid")
	local murdererRoot = murdererCharacter and murdererCharacter:FindFirstChild("HumanoidRootPart")
	if not murdererRoot or not murdererHumanoid or murdererHumanoid.Health <= 0 then return true end
	return (murdererRoot.Position - gunPosition).Magnitude >= 30
end

local function TryPickUpGun(gunDrop)
	if HubState.AutoGunPickupBusy or not HubState.AutoGunPickupEnabled or not gunDrop or not gunDrop.Parent then return end
	if not IsAliveAndInsideActiveMap(gunDrop) then return end
	local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
	local gunCFrame = GetGunDropCFrame(gunDrop)
	if not root or not gunCFrame then return end
	if not HubState.IsGunPickupSafe(gunCFrame.Position) then return end

	HubState.AutoGunPickupBusy = true
	local touchPart = GetGunDropTouchPart(gunDrop)
	if touchPart and type(firetouchinterest) == "function" then
		local character = Player.Character
		local touched = false
		if character then
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then
					pcall(function()
						firetouchinterest(part, touchPart, 0)
						firetouchinterest(part, touchPart, 1)
						touched = true
					end)
				end
			end
		end
		if touched then
			task.delay(0.12, function()
				HubState.AutoGunPickupBusy = false
			end)
			return
		end
	end
	task.wait(0.08)
	if not HubState.AutoGunPickupEnabled or not gunDrop.Parent or not root.Parent or not HubState.IsGunPickupSafe(gunCFrame.Position) then
		HubState.AutoGunPickupBusy = false
		return
	end
	local originalCFrame = root.CFrame
	ThemeObjects.SetRootUpright(root, root.CFrame, gunCFrame.Position + Vector3.new(0, 1.2, 0))
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	task.wait(0.045)
	if root and root.Parent then
		ThemeObjects.SetRootUpright(root, root.CFrame, originalCFrame.Position)
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
	end
	HubState.AutoGunPickupBusy = false
end

local function SetAutoGunPickupEnabled(enabled)
	HubState.AutoGunPickupEnabled = enabled
	HubState.AutoGunToggle.Text = enabled and "On" or "Off"
	HubState.AutoGunTitle.TextColor3 = enabled and AccentColor or InactiveTextColor()
	HubState.LastGunDrop = nil
	HubState.LastGunPickupAttempt = nil
	if enabled then
		task.defer(function()
			local gunDrop = FindGunDrop()
			if gunDrop and gunDrop.Parent then
				HubState.LastGunDrop = gunDrop
				HubState.LastGunPickupAttempt = os.clock()
				TryPickUpGun(gunDrop)
			end
		end)
	end
end

HubState.LastGunDropSearch = 0
HubState.Connections.AutoGunPickup = RunService.Heartbeat:Connect(function()
	if not HubState.AutoGunPickupEnabled or HubState.AutoGunPickupBusy then return end
	-- The recursive workspace search in FindGunDrop is expensive to run every frame;
	-- the gun drop's identity is stable within a round, so a short cache is safe.
	if os.clock() - HubState.LastGunDropSearch >= 0.15 then
		HubState.LastGunDropSearch = os.clock()
		HubState.CachedGunDrop = FindGunDrop()
	end
	local gunDrop = HubState.CachedGunDrop
	if not gunDrop then
		HubState.LastGunDrop = nil
		return
	end

	if gunDrop ~= HubState.LastGunDrop then
		HubState.LastGunDrop = gunDrop
		HubState.LastGunPickupAttempt = 0
	end

	if os.clock() - (HubState.LastGunPickupAttempt or 0) >= 0.25 then
		HubState.LastGunPickupAttempt = os.clock()
		task.delay(HubState.GunPickupDelay, function()
			if HubState.LastGunDrop == gunDrop then
				TryPickUpGun(gunDrop)
			end
		end)
	end
end)

