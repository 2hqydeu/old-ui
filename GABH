local function GetBeeInfo(beeIdOrName)
	local beeConfig = GetBeeConfig()
	if not beeConfig or not beeIdOrName then return nil end
	if type(beeConfig.Get) == "function" then
		local ok, info = pcall(beeConfig.Get, beeIdOrName)
		if ok and info then return info end
	end
	for _, info in ipairs(beeConfig.Roster or {}) do
		if info.Id == beeIdOrName or info.Name == beeIdOrName then
			return info
		end
	end
end

local function GetRarityInfo(rarity)
	local rarityConfig = GetRarityConfig()
	if not rarityConfig or not rarity then return nil end
	if type(rarityConfig.Get) == "function" then
		local ok, info = pcall(rarityConfig.Get, rarity)
		if ok and info then return info end
	end
	for _, info in pairs(rarityConfig.Roster or rarityConfig.List or rarityConfig) do
		if type(info) == "table" and info.Name == rarity then
			return info
		end
	end
end

local function FormatClock(seconds)
	seconds = math.max(0, math.floor(tonumber(seconds) or 0))
	local hours = math.floor(seconds / 3600)
	local minutes = math.floor(seconds % 3600 / 60)
	local secs = seconds % 60
	if hours > 0 then
		return ("%d:%02d:%02d"):format(hours, minutes, secs)
	end
	return ("%02d:%02d"):format(minutes, secs)
end

local function BeeOdds(info)
	if type(info) ~= "table" then return nil end
	local direct = tonumber(info.OddsOneInX or info.OneIn or info.ChanceOneIn or info.RollChance or info.Odds or info.Chance or info.BaseOneInX)
	if direct then return direct end
	local rarityInfo = GetRarityInfo(info.Rarity)
	local base = rarityInfo and tonumber(rarityInfo.BaseOneInX)
	local subWeight = tonumber(info.SubWeight)
	if base and subWeight and subWeight > 0 then
		return math.max(1, math.floor(base * (100 / subWeight) + 0.5))
	end
	return base
end

local function BeeScore(info)
	if type(info) ~= "table" then return 0 end
	local odds = BeeOdds(info)
	if odds then return (odds * 100) + (tonumber(info.SubRank) or 0) end
	return (RarityRank[info.Rarity] or 0) * 1000
end

local function MutationText(mutation)
	if mutation == nil or mutation == "" or mutation == "None" then return "" end
	return " [" .. tostring(mutation) .. "]"
end

local function NormalizeSeasonText(text)
	text = tostring(text or ""):gsub("%[NOW%]%s*", "")
	text = text:gsub("NEXT%s+SEASON", "SEASON")
	text = text:gsub("Next%s+Season", "SEASON")
	text = text:gsub("next%s+season", "SEASON")
	text = text:gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
	local upper = string.upper(text)
	local clock = text:match("%d+:%d%d:%d%d") or text:match("%d+:%d%d")
	if clock then
		for _, season in ipairs(SeasonOptions) do
			if upper:find(string.upper(season), 1, true) then
				return ("%s: %s"):format(string.upper(season), clock)
			end
		end
		if upper:find("SEASON", 1, true) then
			return "SEASON: " .. clock
		end
	end
	return text
end

local function ExtractSeasonName(text)
	local upper = string.upper(tostring(text or ""))
	for _, season in ipairs(SeasonOptions) do
		if upper:find(string.upper(season), 1, true) then
			return string.upper(season)
		end
	end
	return nil
end

local function LooksLikeSeasonTimer(text)
	local upper = string.upper(tostring(text or ""))
	return (upper:find("SEASON", 1, true) or ExtractSeasonName(upper)) and upper:match("%d+:%d%d")
end

local function ReadSeasonTextFromLabel(label)
	if not label or not (label:IsA("TextLabel") or label:IsA("TextButton") or label:IsA("TextBox")) then return nil end
	local text = NormalizeSeasonText(label.Text)
	if LooksLikeSeasonTimer(text) then return text end
	local parent = label.Parent
	if parent then
		local pieces = {}
		for _, child in ipairs(parent:GetDescendants()) do
			if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
				local childText = tostring(child.Text or "")
				if childText ~= "" then table.insert(pieces, childText) end
			end
		end
		text = NormalizeSeasonText(table.concat(pieces, " "))
		if LooksLikeSeasonTimer(text) then return text end
	end
	return nil
end

local function FindSeasonTextFallback(force)
	local now = os.clock()
	local cachedLabel = state.SeasonTextLabel
	if cachedLabel and cachedLabel.Parent and (cachedLabel:IsA("TextLabel") or cachedLabel:IsA("TextButton") or cachedLabel:IsA("TextBox")) then
		local text = ReadSeasonTextFromLabel(cachedLabel)
		if text then
			state.LastSeasonText = text
			return text
		end
	end
	if not force and now - (state.LastSeasonTextScan or 0) < 0.25 then
		return state.LastSeasonText
	end
	state.LastSeasonTextScan = now
	local function resolve(root, path)
		local current = root
		for _, name in ipairs(path) do
			current = current and current:FindFirstChild(name)
			if not current then return nil end
		end
		return current
	end
	for _, label in ipairs({
		resolve(workspace:FindFirstChild("CountdownScreen"), {"Screen", "SurfaceGui", "Board", "NameLabel"}),
		resolve(workspace:FindFirstChild("NatureEvent"), {"EventScreen", "SeasonScreen", "SurfaceGui", "Board", "NameLabel"}),
		resolve(workspace:FindFirstChild("EventScreen"), {"SeasonScreen", "SurfaceGui", "Board", "NameLabel"}),
	}) do
		if label and (label:IsA("TextLabel") or label:IsA("TextButton") or label:IsA("TextBox")) then
			local text = ReadSeasonTextFromLabel(label)
			if text then
				state.SeasonTextLabel = label
				state.LastSeasonText = text
				return text
			end
		end
	end
	local localPlayer = Player
	local roots = {}
	local playerGui = localPlayer and localPlayer:FindFirstChildOfClass("PlayerGui")
	if playerGui then table.insert(roots, playerGui) end
	table.insert(roots, workspace)
	for _, root in ipairs(roots) do
		for _, obj in ipairs(root:GetDescendants()) do
			if (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and (not ScreenGui or not obj:IsDescendantOf(ScreenGui)) then
				local normalized = ReadSeasonTextFromLabel(obj)
				if normalized then
					state.SeasonTextLabel = obj
					state.LastSeasonText = normalized
					return state.LastSeasonText
				end
			end
		end
	end
	state.SeasonTextLabel = nil
	state.LastSeasonText = nil
	return nil
end

