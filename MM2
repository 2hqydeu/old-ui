			localRoot.AssemblyAngularVelocity = Vector3.zero
			if localRoot.AssemblyLinearVelocity.Magnitude > 80 then
				localRoot.AssemblyLinearVelocity = localRoot.AssemblyLinearVelocity.Unit * 18
			end
			ThemeObjects.SetRootUpright(localRoot, localRoot.CFrame, localRoot.Position)
		end
	end
end)

