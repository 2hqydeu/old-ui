	OptimizeScroll.ScrollBarImageColor3 = AccentColor()
	RefreshOptimizeButtons()
	OptimizeFrame.Visible = not OptimizeFrame.Visible
	if OptimizeFrame.Visible and ThemeObjects.UpdateOptimizeDockPosition then
		ThemeObjects.UpdateOptimizeDockPosition()
	end
	UpdateTheme(true)
end

