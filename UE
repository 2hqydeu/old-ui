	-- collapse any stale per-type entries (e.g. "Hunter Trap2") from before types were merged by filter key
	local mergedTypes = {}
	local mergedSelected = {}
	for _, name in ipairs(state.KnownStructureTypes) do
		local key = StructureFilterKey(name)
