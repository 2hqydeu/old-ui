ThemeObjects.Optimizer = ThemeObjects.Optimizer or {}
ThemeObjects.Optimizer.States = ThemeObjects.Optimizer.States or {
	LowGraphics = false,
	NoEffects = false,
	NoParticles = false,
	NoTextures = false,
	NoShadows = false,
	SmoothParts = false,
	HideClutter = false,
	LowWater = false,
}
ThemeObjects.Optimizer.Originals = setmetatable({}, {__mode = "k"})
ThemeObjects.Optimizer.Buttons = {}
ThemeObjects.Optimizer.ApplyToken = (ThemeObjects.Optimizer.ApplyToken or 0) + 1

local function NextOptimizeToken()
	ThemeObjects.Optimizer.ApplyToken = (ThemeObjects.Optimizer.ApplyToken or 0) + 1
	return ThemeObjects.Optimizer.ApplyToken
end

local function OptimizerRemember(object, property)
	if not object then return end
	local bucket = ThemeObjects.Optimizer.Originals[object]
	if not bucket then
		bucket = {}
		ThemeObjects.Optimizer.Originals[object] = bucket
	end
	if bucket[property] ~= nil then return end
	local ok, value = pcall(function()
		return object[property]
	end)
	if ok then bucket[property] = value end
end

local function OptimizerSet(object, property, value)
	if not object then return end
	OptimizerRemember(object, property)
	pcall(function()
		object[property] = value
	end)
end

local function IsOwnCharacterObject(object)
	local character = Player.Character
	return character and object and object:IsDescendantOf(character)
end

local function OptimizerApplyObject(object)
	local states = ThemeObjects.Optimizer.States
	if states.NoParticles then
		if object:IsA("ParticleEmitter") or object:IsA("Trail") or object:IsA("Beam") or object:IsA("Smoke") or object:IsA("Fire") or object:IsA("Sparkles") then
			OptimizerSet(object, "Enabled", false)
		end
	end
	if states.NoEffects then
		if object:IsA("BloomEffect") or object:IsA("BlurEffect") or object:IsA("SunRaysEffect") or object:IsA("DepthOfFieldEffect") or object:IsA("ColorCorrectionEffect") then
			OptimizerSet(object, "Enabled", false)
		elseif object:IsA("Atmosphere") then
			OptimizerSet(object, "Density", 0)
			OptimizerSet(object, "Haze", 0)
			OptimizerSet(object, "Glare", 0)
		end
	end
	if states.NoTextures then
		if object:IsA("Decal") or object:IsA("Texture") then
			OptimizerSet(object, "Transparency", 1)
		end
	end
	if object:IsA("BasePart") then
		if states.NoShadows or states.HideClutter then
			OptimizerSet(object, "CastShadow", false)
		end
		if states.SmoothParts then
			OptimizerSet(object, "Material", Enum.Material.SmoothPlastic)
			OptimizerSet(object, "Reflectance", 0)
		end
		if states.HideClutter and not IsOwnCharacterObject(object) and object.CanCollide == false and object.Transparency < 0.95 and object.Size.Magnitude <= 18 then
			OptimizerSet(object, "LocalTransparencyModifier", 1)
		end
	end
end

local function OptimizerApplyLighting()
	local states = ThemeObjects.Optimizer.States
	local lighting = Lighting
	if states.LowGraphics then
		OptimizerSet(lighting, "GlobalShadows", false)
		OptimizerSet(lighting, "FogEnd", 100000)
		OptimizerSet(lighting, "Brightness", 1.5)
		pcall(function()
			OptimizerSet(lighting, "EnvironmentDiffuseScale", 0)
			OptimizerSet(lighting, "EnvironmentSpecularScale", 0)
		end)
		pcall(function()
			OptimizerSet(settings().Rendering, "QualityLevel", Enum.QualityLevel.Level01)
		end)
	end
	if states.LowWater then
		local terrain = workspace:FindFirstChildOfClass("Terrain")
		if terrain then
			OptimizerSet(terrain, "WaterWaveSize", 0)
			OptimizerSet(terrain, "WaterWaveSpeed", 0)
			OptimizerSet(terrain, "WaterReflectance", 0)
			OptimizerSet(terrain, "WaterTransparency", 1)
		end
	end
end

local function OptimizerAnyEnabled()
	for _, enabled in pairs(ThemeObjects.Optimizer.States) do
		if enabled then return true end
	end
	return false
end

local function OptimizerRestoreAllAsync(token, done)
	task.spawn(function()
		local processed = 0
		for object, properties in pairs(ThemeObjects.Optimizer.Originals) do
			if token ~= ThemeObjects.Optimizer.ApplyToken then return end
			for property, value in pairs(properties) do
				pcall(function()
					object[property] = value
				end)
				processed += 1
				if processed % 120 == 0 then
					task.wait()
				end
			end
		end
		if token ~= ThemeObjects.Optimizer.ApplyToken then return end
		ThemeObjects.Optimizer.Originals = setmetatable({}, {__mode = "k"})
		if done then done() end
	end)
end

local function OptimizerApplyActiveAsync(token)
	if not OptimizerAnyEnabled() then
		OptimizeStatus.Text = "Ready"
		return
	end
	OptimizerApplyLighting()
	OptimizeStatus.Text = "Applying..."
	task.spawn(function()
		local processed = 0
		local playerGui = Player and Player:FindFirstChildOfClass("PlayerGui")
		local roots = {workspace, Lighting, playerGui}
		for _, root in ipairs(roots) do
			if token ~= ThemeObjects.Optimizer.ApplyToken then return end
			if root then
				OptimizerApplyObject(root)
				for _, object in ipairs(root:GetDescendants()) do
					if token ~= ThemeObjects.Optimizer.ApplyToken then return end
					OptimizerApplyObject(object)
					processed += 1
					if processed % 140 == 0 then
						OptimizeStatus.Text = "Applying " .. tostring(processed)
						task.wait()
					end
				end
			end
		end
		if token == ThemeObjects.Optimizer.ApplyToken then
			OptimizeStatus.Text = "Applied"
		end
	end)
end

local function RefreshOptimizeButtons()
	for _, entry in ipairs(ThemeObjects.Optimizer.Buttons) do
		if entry.Kind == "Restore" then
			entry.Button.Text = "Restore"
			entry.Button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
			entry.Button.BackgroundTransparency = 0
		elseif entry.Kind == "Boost" then
			entry.Button.Text = "FPS Boost"
			entry.Button.BackgroundColor3 = OptimizerAnyEnabled() and AccentColor() or Color3.fromRGB(45, 45, 45)
			entry.Button.BackgroundTransparency = OptimizerAnyEnabled() and 0 or 0.8
		else
			local enabled = ThemeObjects.Optimizer.States[entry.Kind] == true
			entry.Button.Text = (enabled and "On  " or "Off ") .. entry.Label
			entry.Button.BackgroundColor3 = enabled and AccentColor() or Color3.fromRGB(45, 45, 45)
			entry.Button.BackgroundTransparency = enabled and 0 or 0.8
		end
	end
end

local function FinishOptimizerChange()
	RefreshOptimizeButtons()
	UpdateTheme(true)
end

local function SetOptimizerFeature(kind, enabled)
	ThemeObjects.Optimizer.States[kind] = enabled
	local token = NextOptimizeToken()
	if enabled then
		OptimizerApplyActiveAsync(token)
	else
		OptimizeStatus.Text = "Restoring..."
		OptimizerRestoreAllAsync(token, function()
			OptimizerApplyActiveAsync(token)
		end)
	end
	FinishOptimizerChange()
end

local function RestoreOptimizer()
	for kind in pairs(ThemeObjects.Optimizer.States) do
		ThemeObjects.Optimizer.States[kind] = false
	end
	local token = NextOptimizeToken()
	OptimizeStatus.Text = "Restoring..."
	OptimizerRestoreAllAsync(token, function()
		OptimizeStatus.Text = "Restored"
	end)
	FinishOptimizerChange()
end

local function ApplyFpsBoost()
	for kind in pairs(ThemeObjects.Optimizer.States) do
		ThemeObjects.Optimizer.States[kind] = true
	end
	local token = NextOptimizeToken()
	OptimizerApplyActiveAsync(token)
	FinishOptimizerChange()
end

local function CreateOptimizeOption(kind, label, y)
	local button = Instance.new("TextButton")
	button.Name = "Optimize" .. kind
	button.Size = UDim2.new(0, 110, 0, 20)
	button.Position = UDim2.new(0, 0, 0, y)
	button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	button.BackgroundTransparency = 0.8
	button.BorderSizePixel = 0
	button.Text = label
	button.Font = Enum.Font.GothamBold
	button.TextSize = 7
	button.TextColor3 = Color3.fromRGB(255, 255, 255)
	button.TextXAlignment = Enum.TextXAlignment.Center
	button.ZIndex = 82
	button.Parent = OptimizeScroll
	AddText(button)
	Instance.new("UICorner", button).CornerRadius = UDim.new(0, 5)
	local stroke = Instance.new("UIStroke")
	stroke.Name = "ControlOutline"
	stroke.Color = Color3.fromRGB(0, 0, 0)
	stroke.Thickness = 1
	stroke.Transparency = 0.18
	stroke.Parent = button
	table.insert(ThemeObjects.Optimizer.Buttons, {Button = button, Kind = kind, Label = label})
	return button
end

