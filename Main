-- Dragging
HubState.dragging = nil
HubState.dragStart = nil
HubState.startPos = nil
TrackConnection("MainFrameDragStart", MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	HubState.dragging = true
	HubState.dragStart = input.Position
	HubState.startPos = MainFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState ~= Enum.UserInputState.End then return end
		HubState.dragging = false
		if HubState.minimized then
			SnapMinimizedToNearestSide(true)
		else
			HubState.PreMinimizePosition = MainFrame.Position
		end
	end)
end))
TrackConnection("MainFrameDragMove", UserInputService.InputChanged:Connect(function(input)
	if not HubState.dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - HubState.dragStart
	MainFrame.Position = UDim2.new(HubState.startPos.X.Scale, HubState.startPos.X.Offset + delta.X, HubState.startPos.Y.Scale, HubState.startPos.Y.Offset + delta.Y)
end))

-- FLY-IN TITLE SEQUENCE
task.spawn(function()
	SplashFrame.Rotation = -540
	local spinIn = TweenService:Create(SplashFrame, TweenInfo.new(0.55, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 200, 0, 200),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Rotation = 0,
	})
	spinIn:Play()
	spinIn.Completed:Wait()

	local revealTitle = TweenService:Create(SplashText, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		TextTransparency = 0,
		TextStrokeTransparency = 0.5,
	})
	revealTitle:Play()
	revealTitle.Completed:Wait()
	task.wait(0.5)

	local splashStroke = SplashFrame:FindFirstChildOfClass("UIStroke")
	if splashStroke then
		TweenService:Create(splashStroke, TweenInfo.new(0.4), {Transparency = 1}):Play()
	end
	TweenService:Create(SplashText, TweenInfo.new(0.25), {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
	local spinOut = TweenService:Create(SplashFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
		Size = UDim2.new(0, 0, 0, 0),
		Rotation = 540,
		BackgroundTransparency = 1,
	})
	spinOut:Play()
	spinOut.Completed:Wait()
	SplashFrame:Destroy()
	MainFrame.Visible = true
end)
