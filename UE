local function DiscoverRarityTiers()
	local tiers = {}
	local itemsFolder = game.ReplicatedStorage:FindFirstChild("Items")
	local dropsFolder = itemsFolder and itemsFolder:FindFirstChild("Drops")
	if dropsFolder then
		for _, child in ipairs(dropsFolder:GetChildren()) do
			if child:IsA("Folder") then
				table.insert(tiers, child.Name)
			end
		end
	end
	return tiers
end

local RARITY_TIERS = DiscoverRarityTiers()
local KNOWN_RARITY_SET = {}
for _, tier in ipairs(RARITY_TIERS) do
	KNOWN_RARITY_SET[tier] = true
	if state.SelectedRarities[tier] == nil then state.SelectedRarities[tier] = true end
	if state.ESPSelectedRarities[tier] == nil then state.ESPSelectedRarities[tier] = false end
end

local function GetDropRarity(part)
	for _, descendant in ipairs(part:GetDescendants()) do
		if (descendant:IsA("TextLabel") or descendant:IsA("TextButton")) and KNOWN_RARITY_SET[tostring(descendant.Text)] then
			return tostring(descendant.Text)
		end
	end
	return nil
end

