local function ApplyBackgroundTransparency(value)
	BackgroundTransparencyValue = math.clamp(math.floor(value + 0.5), 0, 100)
	BackgroundTransparencyValueLabel.Text = BackgroundTransparencyValue .. "%"
	MainFrame.BackgroundTransparency = BackgroundTransparencyValue / 100
	SavedKeybinds.BackgroundTransparency = BackgroundTransparencyValue
	SavePersistentSettings()
end
BackgroundTransparencyMinusBtn.MouseButton1Click:Connect(function()
	PlayClick()
	ApplyBackgroundTransparency(BackgroundTransparencyValue - 5)
end)
BackgroundTransparencyPlusBtn.MouseButton1Click:Connect(function()
	PlayClick()
	ApplyBackgroundTransparency(BackgroundTransparencyValue + 5)
end)
BackgroundTransparencyValueLabel.FocusLost:Connect(function()
	local typed = tonumber((BackgroundTransparencyValueLabel.Text:gsub("%%", "")))
	ApplyBackgroundTransparency(typed or BackgroundTransparencyValue)
end)
BackgroundTransparencyBackBtn.MouseButton1Click:Connect(function()
	PlayClick()
	BackgroundTransparencyFrame.Visible = false
	ThemeFrame.Visible = true
	if ThemeObjects.UpdateThemeDockPosition then
		ThemeObjects.UpdateThemeDockPosition()
	end
end)

