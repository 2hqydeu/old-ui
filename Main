-- Games hub
HubState.GamesTabButton = nil
HubState.SelectedGame = nil

local function CreateGameLauncherButton(name, text, order, url, label, openFunctionName)
	local button = Instance.new("TextButton")
	button.Name = name
	button.LayoutOrder = order
	button.Size = UDim2.new(0, 156, 0, 60)
	button.BackgroundColor3 = Color3.fromRGB(65, 65, 67)
	button.BackgroundTransparency = 0.92
	button.BorderSizePixel = 0
	button.Text = text
	button.Font = Enum.Font.GothamBold
	button.TextSize = 12
	button.TextWrapped = true
	button.TextColor3 = Color3.fromRGB(255, 255, 255)
	button.Parent = HubState.GamesPage
	table.insert(ThemeObjects.Backgrounds, button)
	table.insert(ThemeObjects.Texts, button)
	Instance.new("UICorner", button).CornerRadius = UDim.new(0, 8)

	local stroke = Instance.new("UIStroke")
	stroke.Name = "ControlOutline"
	stroke.Color = AccentColor
	stroke.Thickness = 1
	stroke.Transparency = 0.75
	stroke.Parent = button
	table.insert(ThemeObjects.Accents, stroke)

	button.MouseButton1Click:Connect(function()
		PlayClick()
		if ThemeObjects[openFunctionName] then
			ThemeObjects[openFunctionName]()
			return
		end
		ThemeObjects.ScriptRunner.RunOnceUrl(label:gsub("%s+", ""), url, label)
	end)
	return button
end

