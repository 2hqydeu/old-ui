local packetsCache = nil
local function GetPackets()
	if packetsCache ~= nil and packetsCache ~= false then return packetsCache end
	if packetsCache == false and os.clock() - (state.LastPacketsRequire or 0) < 3 then
		return nil, "Packets not found"
	end
	state.LastPacketsRequire = os.clock()
	local replicatedStorage = game:GetService("ReplicatedStorage")
	local packages = replicatedStorage:FindFirstChild("Packages")
	local packetsModule = packages and packages:FindFirstChild("Packets")
	if not packetsModule then
		packetsCache = false
		return nil, "Packets not found"
	end
	local ok, result = pcall(require, packetsModule)
	if not ok then
		packetsCache = false
		return nil, tostring(result)
	end
	packetsCache = result
	return packetsCache
end

local function FirePacket(name, payload)
	local packets, reason = GetPackets()
	if not packets or not packets[name] then
		return false, {Reason = reason or (name .. " packet missing")}
	end
	local callOk, packetOk, response = pcall(function()
		if payload == nil then
			return packets[name]:Fire()
		end
		return packets[name]:Fire(payload)
	end)
	if not callOk then
		return false, {Reason = tostring(packetOk)}
	end
	return packetOk, response
end

local function FireTrashBee()
	local packets = GetPackets()
	if not packets or not packets.TrashBee then return false end
	return pcall(function()
		packets.TrashBee:Fire()
	end)
end

local function BeeMetaMatches(beeId, mutation, kind, value)
	local info = GetBeeInfo(beeId)
	if not info then return false end
	if kind == "Rarity" then
		return info.Rarity == value and (info.RollEvent == nil or info.RollEvent == "")
	end
	if kind == "Season" then
		return info.RollEvent == value
	end
	if kind == "Mutation" then
		local name = mutation
		if name == nil or name == "" then name = "None" end
		return name == value
	end
	return false
end

local function BeeToolMatches(tool, kind, value)
	if not tool or not tool:IsA("Tool") then return false end
	if tool:GetAttribute("Kind") ~= "Bee" then return false end
	return BeeMetaMatches(tool:GetAttribute("Id"), tool:GetAttribute("Mutation"), kind, value)
end

local function FindMatchingBeeTool(kind, value)
	local player = Player
	local character = player and player.Character
	if character then
		for _, child in ipairs(character:GetChildren()) do
			if BeeToolMatches(child, kind, value) then
				return child
			end
		end
	end
	local backpack = player and player:FindFirstChildOfClass("Backpack")
	if backpack then
		for _, child in ipairs(backpack:GetChildren()) do
			if BeeToolMatches(child, kind, value) then
				return child
			end
		end
	end
end

local function TrashMatchingBeeTools(kind, value)
	if state.BeeTrashBusy then return end
	state.BeeTrashBusy = true
	beeSellStatus.Text = "Checking inventory..."
	local player = Player
	local character = player and player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		beeSellStatus.Text = "No character"
		state.BeeTrashBusy = false
		return
	end
	local trashed = 0
	for _ = 1, 75 do
		local tool = FindMatchingBeeTool(kind, value)
		if not tool then break end
		local toolUuid = tool:GetAttribute("UUID")
		beeSellStatus.Text = "Trashing " .. tostring(tool.Name)
		if tool.Parent ~= character then
			humanoid:EquipTool(tool)
			local equipStart = os.clock()
			repeat
				task.wait(0.04)
			until tool.Parent == character or os.clock() - equipStart > 1
		end
		if tool.Parent ~= character then
			beeSellStatus.Text = "Could not equip bee"
			break
		end
		local ok = FireTrashBee()
		if ok then
			trashed += 1
			local started = os.clock()
			repeat
				task.wait(0.05)
			until not tool.Parent or tool:GetAttribute("UUID") ~= toolUuid or os.clock() - started > 1.25
		else
			break
		end
	end
	beeSellStatus.Text = trashed > 0 and ("Trashed " .. tostring(trashed)) or "None found"
	state.BeeTrashBusy = false
end

local function IsSelectedMutation(mutation)
	local name = mutation
	if name == nil or name == "" then name = "None" end
	return state.SelectedMutations[name] == true
end

local function IsSelectedSeason(season)
	return season ~= nil and state.SelectedSeasons[season] == true
end

local function ResultMatches(result)
	if type(result) ~= "table" then return false end
	local rarity = result.Rarity or "Common"
	local info = GetBeeInfo(result.BeeId or result.Name or result.Bee)
	if info and IsSelectedSeason(info.RollEvent) then
		return IsSelectedMutation(result.Mutation)
	end
	return state.SelectedRarities[rarity] == true and IsSelectedMutation(result.Mutation)
end

local function SortedResults(results)
	local sorted = {}
	for _, result in pairs(type(results) == "table" and results or {}) do
		table.insert(sorted, result)
	end
	table.sort(sorted, function(a, b)
		return (tonumber(a.Podium) or 255) < (tonumber(b.Podium) or 255)
	end)
	return sorted
end

local function UpdateRollSummary(summary)
	state.RollCount = (tonumber(state.RollCount) or 0) + 1
	state.LastRollSummary = ("Rolls: %d"):format(state.RollCount)
	if summary and summary ~= "" then
		state.LastRollSummary = state.LastRollSummary .. " | " .. summary
	end
	rollStatusDisplay.Text = state.LastRollSummary
end

local function BestRollSummary(results)
	local bestResult, bestInfo, bestScore = nil, nil, -1
	for _, result in ipairs(SortedResults(results)) do
		local info = GetBeeInfo(result.BeeId or result.Name or result.Bee)
		local score = BeeScore(info)
		if info and score > bestScore then
			bestResult = result
			bestInfo = info
			bestScore = score
		end
	end
	if not bestInfo then return nil end
	return (bestInfo.Name or bestResult.Name or "Bee") .. MutationText(bestResult and bestResult.Mutation)
end

local function RefreshPromptCache(force)
	local now = os.clock()
	if not force and now - (state.LastPromptRefresh or 0) < 0.45 then
		return state.PromptCache
	end
	state.LastPromptRefresh = now
	local cache = {Roll = nil, Buy = {}}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			local action = string.lower(obj.ActionText or "")
			local objectText = string.lower(obj.ObjectText or "")
			if not cache.Roll and action:find("roll", 1, true) and (objectText:find("roll", 1, true) or objectText:find("bee", 1, true)) then
				cache.Roll = obj
			elseif action:find("buy", 1, true) or action:find("claim", 1, true) then
				table.insert(cache.Buy, obj)
			end
		end
	end
	state.PromptCache = cache
	return cache
end

local function FindRollPrompt()
	local farmRef = SafeRequire({"ReplicatedStorage", "Scripts", "Modules", "FarmRef"})
	local plotNav = SafeRequire({"ReplicatedStorage", "Modules", "PlotNav"})
	local ok, farm = pcall(function()
		return farmRef and farmRef.TryGet and farmRef.TryGet()
	end)
	local okPart, rollPart = pcall(function()
		return ok and farm and plotNav and plotNav.GetRollPart and plotNav.GetRollPart(farm)
	end)
	local prompt = okPart and rollPart and rollPart:FindFirstChildWhichIsA("ProximityPrompt")
	if prompt then return prompt end
	return RefreshPromptCache(true).Roll
end

local function FindText(root, name)
	if not root then return nil end
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("TextLabel") and obj.Name == name then
			return obj.Text
		end
	end
	return nil
end

local function PromptMatches(prompt)
	local parent = prompt.Parent
	local rarity = FindText(parent, "Rarity") or "Common"
	local mutation = FindText(parent, "Mutation")
	local beeName = prompt.ObjectText or FindText(parent, "Name")
	local info = GetBeeInfo(beeName)
	if info and IsSelectedSeason(info.RollEvent) then
		return IsSelectedMutation(mutation)
	end
	return state.SelectedRarities[rarity] == true and IsSelectedMutation(mutation)
end

local function AutoBuyResults(results)
	if state.BuyBusy then return 0 end
	state.BuyBusy = true
	local bought = 0
	for _, result in ipairs(SortedResults(results)) do
		if ResultMatches(result) and result.Podium then
			local ok = FirePacket("BuyBee", {Podium = result.Podium})
			if ok then
				bought += 1
				local info = GetBeeInfo(result.BeeId or result.Name or result.Bee)
				RecordPurchase(info and info.Name or result.Name or result.BeeId or "Bee", result.Rarity, result.Mutation)
				task.wait(0.1)
			end
		end
	end
	state.BuyBusy = false
	return bought
end

local function TryExistingBuyPrompts(maxPasses, passDelay)
	if state.BuyBusy then return end
	if type(fireproximityprompt) ~= "function" then return end
	state.BuyBusy = true
	maxPasses = maxPasses or 1
	passDelay = passDelay or 0.18
	for pass = 1, maxPasses do
		local cache = RefreshPromptCache(true)
		for _, prompt in ipairs(cache.Buy) do
			if prompt and prompt.Parent and PromptMatches(prompt) then
				local beeName = prompt.ObjectText or FindText(prompt.Parent, "Name") or "Bee"
				local rarity = FindText(prompt.Parent, "Rarity") or "?"
				local mutation = FindText(prompt.Parent, "Mutation")
				fireproximityprompt(prompt)
				RecordPurchase(beeName, rarity, mutation)
				task.wait(0.08)
			end
		end
		if pass < maxPasses then task.wait(passDelay) end
	end
	state.BuyBusy = false
end

local function DoEquipBest()
	if state.EquipBusy then return end
	state.EquipBusy = true
	FirePacket("EquipBest")
	state.EquipBusy = false
end

local function DoRoll()
	if state.RollBusy then return end
	state.RollBusy = true
	local ok, response = FirePacket("RequestRoll")
	if ok then
		task.wait(0.35)
		UpdateRollSummary(response and response.Results and BestRollSummary(response.Results) or "packet")
		if response and response.Results and state.AutoBuy then
			AutoBuyResults(response.Results)
		elseif state.AutoBuy then
			TryExistingBuyPrompts(3, 0.2)
		end
		if state.AutoEquip then DoEquipBest() end
		state.RollBusy = false
		return
	end
	if type(fireproximityprompt) == "function" then
		local prompt = FindRollPrompt()
		if prompt and prompt.Parent then
			fireproximityprompt(prompt)
			task.wait(1.75)
			UpdateRollSummary("prompt")
			if state.AutoBuy then TryExistingBuyPrompts(3, 0.2) end
			if state.AutoEquip then DoEquipBest() end
			state.RollBusy = false
			return
		end
	end
	if state.AutoEquip then DoEquipBest() end
	state.RollBusy = false
end

local function DoSell()
	if state.SellBusy then return end
	state.SellBusy = true
	FirePacket("GrabHoney")
	task.wait(0.12)
	FirePacket("SellHoney")
	state.SellBusy = false
end

