ThemeObjects.ScriptRunner = {}
ThemeObjects.ScriptRunner.Notify = function(message)
	if ThemeObjects.ShowNotification then
		ThemeObjects.ShowNotification(message)
	end
end

ThemeObjects.ScriptRunner.RunSource = function(source, label)
	source = tostring(source or "")
	if source:gsub("%s+", "") == "" then
		ThemeObjects.ScriptRunner.Notify("No script entered")
		return
	end
	if type(loadstring) ~= "function" then
		ThemeObjects.ScriptRunner.Notify("loadstring is unavailable")
		return
	end
	local chunk, compileError = loadstring(source)
	if not chunk then
		ThemeObjects.ScriptRunner.Notify("Script error: " .. tostring(compileError):sub(1, 80))
		return
	end
	local success, runtimeError = pcall(chunk)
	if success then
		ThemeObjects.ScriptRunner.Notify((label or "Script") .. " executed")
	else
		ThemeObjects.ScriptRunner.Notify("Run error: " .. tostring(runtimeError):sub(1, 80))
	end
end

ThemeObjects.ScriptRunner.RunUrl = function(url, label)
	url = tostring(url or ""):match("^%s*(.-)%s*$")
	if url == "" then
		ThemeObjects.ScriptRunner.Notify("No URL entered")
		return
	end
	if not url:match("^https?://") then
		ThemeObjects.ScriptRunner.Notify("URL must start with http")
		return
	end
	local success, source = pcall(function()
		return game:HttpGet(url)
	end)
	if not success or type(source) ~= "string" or source == "" then
		ThemeObjects.ScriptRunner.Notify("Could not fetch script")
		return
	end
	ThemeObjects.ScriptRunner.RunSource(source, label)
end

ThemeObjects.ScriptRunner.Loaded = {}
ThemeObjects.ScriptRunner.InfiniteYieldLoading = false
ThemeObjects.ScriptRunner.InfiniteYieldLoadToken = 0
ThemeObjects.ScriptRunner.InfiniteYieldBaseline = nil
ThemeObjects.ScriptRunner.InfiniteYieldLoadedByHub = false
ThemeObjects.ScriptRunner.InfiniteYieldGuiTargets = {}
ThemeObjects.ScriptRunner.InfiniteYieldConnectionSnapshot = nil
ThemeObjects.ScriptRunner.GetInfiniteYieldSignals = function()
	local signals = {
		UserInputService.InputBegan,
		UserInputService.InputEnded,
		UserInputService.InputChanged,
		RunService.RenderStepped,
		RunService.Heartbeat,
		RunService.Stepped,
		Players.PlayerAdded,
		Players.PlayerRemoving,
		Player.CharacterAdded,
		Player.CharacterRemoving,
		Player.Chatted,
	}
	pcall(function()
		local mouse = Player:GetMouse()
		table.insert(signals, mouse.KeyDown)
		table.insert(signals, mouse.KeyUp)
		table.insert(signals, mouse.Button1Down)
		table.insert(signals, mouse.Button1Up)
		table.insert(signals, mouse.Button2Down)
		table.insert(signals, mouse.Button2Up)
		table.insert(signals, mouse.Move)
	end)
	pcall(function()
		local camera = workspace.CurrentCamera
		if camera then
			table.insert(signals, camera:GetPropertyChangedSignal("CameraType"))
			table.insert(signals, camera:GetPropertyChangedSignal("CameraSubject"))
			table.insert(signals, camera:GetPropertyChangedSignal("CFrame"))
		end
	end)
	return signals
end
ThemeObjects.ScriptRunner.CaptureInfiniteYieldConnections = function()
	if type(getconnections) ~= "function" then
		ThemeObjects.ScriptRunner.InfiniteYieldConnectionSnapshot = nil
		return false
	end
	local snapshot = {}
	for _, signal in ipairs(ThemeObjects.ScriptRunner.GetInfiniteYieldSignals()) do
		pcall(function()
			for _, connection in ipairs(getconnections(signal)) do
				snapshot[connection] = true
			end
		end)
	end
	ThemeObjects.ScriptRunner.InfiniteYieldConnectionSnapshot = snapshot
	return true
end
ThemeObjects.ScriptRunner.DisconnectInfiniteYieldConnections = function()
	local snapshot = ThemeObjects.ScriptRunner.InfiniteYieldConnectionSnapshot
	if type(getconnections) ~= "function" or type(snapshot) ~= "table" then return false end
	local disconnected = 0
	for _, signal in ipairs(ThemeObjects.ScriptRunner.GetInfiniteYieldSignals()) do
		pcall(function()
			for _, connection in ipairs(getconnections(signal)) do
				if not snapshot[connection] then
					local stopped = false
					pcall(function()
						if type(connection.Disable) == "function" then
							connection:Disable()
							stopped = true
						end
					end)
					pcall(function()
						if not stopped and type(connection.Disconnect) == "function" then
							connection:Disconnect()
							stopped = true
						end
					end)
					pcall(function()
						if connection.Enabled ~= nil then connection.Enabled = false end
					end)
					if stopped then disconnected = disconnected + 1 end
				end
			end
		end)
	end
	return disconnected > 0
end
ThemeObjects.ScriptRunner.CaptureInfiniteYieldBaseline = function()
	local lighting = Lighting
	local camera = workspace.CurrentCamera
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	ThemeObjects.ScriptRunner.InfiniteYieldBaseline = {
		Lighting = {
			Brightness = lighting.Brightness,
			ClockTime = lighting.ClockTime,
			FogEnd = lighting.FogEnd,
			FogStart = lighting.FogStart,
			GlobalShadows = lighting.GlobalShadows,
			Ambient = lighting.Ambient,
			OutdoorAmbient = lighting.OutdoorAmbient,
			ExposureCompensation = lighting.ExposureCompensation,
		},
		Camera = camera and {
			FieldOfView = camera.FieldOfView,
			CameraType = camera.CameraType,
			CameraSubject = camera.CameraSubject,
		} or nil,
		Humanoid = humanoid and {
			WalkSpeed = humanoid.WalkSpeed,
			JumpPower = humanoid.JumpPower,
			JumpHeight = humanoid.JumpHeight,
			HipHeight = humanoid.HipHeight,
			UseJumpPower = humanoid.UseJumpPower,
			AutoRotate = humanoid.AutoRotate,
		} or nil,
		RootAnchored = root and root.Anchored or nil,
	}
end
ThemeObjects.ScriptRunner.FindInfiniteYieldGuiTargets = function()
	local targets = {}
	local function scan(root)
		if not root then return end
		for _, item in ipairs(root:GetDescendants()) do
			local isTitle = item:IsA("TextLabel") and item.Name == "Title" and tostring(item.Text):find("Infinite Yield", 1, true)
			local isCommandBar = item:IsA("TextBox") and item.Name == "Cmdbar" and tostring(item.PlaceholderText):find("Command Bar", 1, true)
			if isTitle or isCommandBar then
				local top = item
				local previous = item
				while top.Parent and top.Parent ~= root do
					if top:IsA("ScreenGui") then break end
					previous = top
					top = top.Parent
				end
				if top.Name == "RobloxGui" then top = previous end
				targets[top] = true
			end
		end
	end
	pcall(function() scan(CoreGui) end)
	pcall(function()
		if get_hidden_gui or gethui then
			local hiddenRoot = (get_hidden_gui or gethui)()
			if hiddenRoot ~= CoreGui then scan(hiddenRoot) end
		end
	end)
	ThemeObjects.ScriptRunner.InfiniteYieldGuiTargets = targets
	return targets
end
ThemeObjects.ScriptRunner.SetInfiniteYieldGuiVisible = function(visible)
	local targets = ThemeObjects.ScriptRunner.InfiniteYieldGuiTargets
	if type(targets) ~= "table" or not next(targets) then
		targets = ThemeObjects.ScriptRunner.FindInfiniteYieldGuiTargets()
	end
	local changed = false
	for target in pairs(targets) do
		if target and target.Parent then
			changed = true
			pcall(function()
				if target:IsA("ScreenGui") then
					target.Enabled = visible
				elseif target:IsA("GuiObject") then
					target.Visible = visible
				end
			end)
		else
			targets[target] = nil
		end
	end
	return changed
end
ThemeObjects.ScriptRunner.DestroyInfiniteYield = function(options)
	options = type(options) == "table" and options or {}
	local baseline = ThemeObjects.ScriptRunner.InfiniteYieldBaseline
	local lighting = Lighting
	if options.Hard then
		ThemeObjects.ScriptRunner.DisconnectInfiniteYieldConnections()
	end
	pcall(function()
		if baseline and baseline.Lighting then
			for property, value in pairs(baseline.Lighting) do
				lighting[property] = value
			end
		end
	end)
	pcall(function()
		if options.Hard then
			if type(getgenv) == "function" then getgenv().IY_LOADED = false end
			IY_LOADED = false
		end
	end)
	local function cleanInfiniteYieldVisuals(root)
		if not root then return end
		for _, item in ipairs(root:GetDescendants()) do
			local itemName = tostring(item.Name)
			if itemName:sub(-4) == "_ESP" or itemName:sub(-5) == "_CHMS" or itemName:sub(-3) == "_LC"
				or (item:IsA("BoxHandleAdornment") and itemName:sub(-5) == "_PESP") then
				item:Destroy()
			end
		end
	end
	pcall(function() cleanInfiniteYieldVisuals(CoreGui) end)
	pcall(function()
		if get_hidden_gui or gethui then
			local hiddenRoot = (get_hidden_gui or gethui)()
			if hiddenRoot ~= CoreGui then
				cleanInfiniteYieldVisuals(hiddenRoot)
			end
		end
	end)
	if options.Hard then
		for target in pairs(ThemeObjects.ScriptRunner.FindInfiniteYieldGuiTargets()) do
			pcall(function()
				if target and target.Parent then target:Destroy() end
			end)
		end
	else
		ThemeObjects.ScriptRunner.SetInfiniteYieldGuiVisible(false)
	end
	pcall(function()
		for _, player in ipairs(Players:GetPlayers()) do
			local character = player.Character
			if character then
				for _, object in ipairs(character:GetDescendants()) do
					if object:IsA("BoxHandleAdornment") and object.Name:sub(-5) == "_PESP" then
						object:Destroy()
					end
				end
			end
		end
	end)
	pcall(function()
		local character = Player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if humanoid then
			humanoid.PlatformStand = false
			humanoid.Sit = false
			humanoid.AutoRotate = baseline and baseline.Humanoid and baseline.Humanoid.AutoRotate or true
			humanoid.WalkSpeed = baseline and baseline.Humanoid and baseline.Humanoid.WalkSpeed or 16
			if humanoid.UseJumpPower ~= nil and baseline and baseline.Humanoid and baseline.Humanoid.UseJumpPower ~= nil then
				humanoid.UseJumpPower = baseline.Humanoid.UseJumpPower
			end
			if baseline and baseline.Humanoid then
				humanoid.JumpPower = baseline.Humanoid.JumpPower
				humanoid.JumpHeight = baseline.Humanoid.JumpHeight
				humanoid.HipHeight = baseline.Humanoid.HipHeight
			else
				humanoid.JumpPower = 50
				humanoid.JumpHeight = 7.2
			end
		end
		if root then
			root.Anchored = baseline and baseline.RootAnchored or false
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
			for _, child in ipairs(root:GetChildren()) do
				if child:IsA("BodyVelocity") or child:IsA("BodyGyro") or child:IsA("BodyPosition") or child:IsA("BodyAngularVelocity") or child:IsA("BodyForce") then
					child:Destroy()
				end
			end
		end
	end)
	pcall(function()
		local camera = workspace.CurrentCamera
		local character = Player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if camera then
			if baseline and baseline.Camera then
				camera.FieldOfView = baseline.Camera.FieldOfView
				camera.CameraType = baseline.Camera.CameraType
				camera.CameraSubject = baseline.Camera.CameraSubject or humanoid
			else
				camera.FieldOfView = 70
				camera.CameraType = Enum.CameraType.Custom
				camera.CameraSubject = humanoid
			end
		end
	end)
	if not options.Quiet then
		ThemeObjects.ScriptRunner.Notify("Infinite Yield cleanup ran")
	end
end
ThemeObjects.ScriptRunner.LoadInfiniteYield = function()
	if ThemeObjects.ScriptRunner.InfiniteYieldLoading then
		ThemeObjects.ScriptRunner.Notify("Infinite Yield is already loading")
		return
	end
	if ThemeObjects.ScriptRunner.InfiniteYieldLoadedByHub and ThemeObjects.ScriptRunner.SetInfiniteYieldGuiVisible(true) then
		if HubState.InfiniteYieldDestroy then
			HubState.InfiniteYieldDestroy.Visible = true
		end
		ThemeObjects.ScriptRunner.Notify("Infinite Yield restored")
		return
	end
	ThemeObjects.ScriptRunner.InfiniteYieldLoading = true
	ThemeObjects.ScriptRunner.InfiniteYieldLoadToken = ThemeObjects.ScriptRunner.InfiniteYieldLoadToken + 1
	local loadToken = ThemeObjects.ScriptRunner.InfiniteYieldLoadToken
	if HubState.InfiniteYieldExecute then
		HubState.InfiniteYieldExecute.Active = false
		HubState.InfiniteYieldExecute.AutoButtonColor = false
		HubState.InfiniteYieldExecute.Text = "Loading"
	end
	task.delay(0.18, function()
		if loadToken ~= ThemeObjects.ScriptRunner.InfiniteYieldLoadToken then return end
		pcall(function()
			if type(getgenv) == "function" then getgenv().IY_LOADED = false end
			IY_LOADED = false
		end)
		ThemeObjects.ScriptRunner.CaptureInfiniteYieldBaseline()
		ThemeObjects.ScriptRunner.CaptureInfiniteYieldConnections()
		ThemeObjects.ScriptRunner.RunSource([[loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source"))()]], "Infinite Yield")
		ThemeObjects.ScriptRunner.InfiniteYieldLoadedByHub = true
		task.defer(function()
			ThemeObjects.ScriptRunner.FindInfiniteYieldGuiTargets()
		end)
		if HubState.InfiniteYieldExecute then
			HubState.InfiniteYieldExecute.Text = "Execute"
			HubState.InfiniteYieldExecute.Active = true
			HubState.InfiniteYieldExecute.AutoButtonColor = true
		end
		if HubState.InfiniteYieldDestroy then
			HubState.InfiniteYieldDestroy.Visible = true
		end
		ThemeObjects.ScriptRunner.InfiniteYieldLoading = false
	end)
end
ThemeObjects.ScriptRunner.RunOnceUrl = function(key, url, label)
	key = tostring(key or label or url or "Script")
	if ThemeObjects.ScriptRunner.Loaded[key] then
		ThemeObjects.ScriptRunner.Notify((label or key) .. " already loaded")
		return
	end
	url = tostring(url or ""):match("^%s*(.-)%s*$")
	if url == "" then
		ThemeObjects.ScriptRunner.Notify("No URL entered")
		return
	end
	if not url:match("^https?://") then
		ThemeObjects.ScriptRunner.Notify("URL must start with http")
		return
	end
	local success, source = pcall(function()
		return game:HttpGet(url)
	end)
	if not success or type(source) ~= "string" or source == "" then
		ThemeObjects.ScriptRunner.Notify("Could not fetch " .. (label or "script"))
		return
	end
	if type(loadstring) ~= "function" then
		ThemeObjects.ScriptRunner.Notify("loadstring is unavailable")
		return
	end
	local chunk, compileError = loadstring(source)
	if not chunk then
		ThemeObjects.ScriptRunner.Notify("Script error: " .. tostring(compileError):sub(1, 80))
		return
	end
	local ran, runtimeError = pcall(chunk)
	if ran then
		ThemeObjects.ScriptRunner.Loaded[key] = true
		ThemeObjects.ScriptRunner.Notify((label or key) .. " loaded")
	else
		ThemeObjects.ScriptRunner.Notify("Run error: " .. tostring(runtimeError):sub(1, 80))
	end
end

local function CreateScriptCard(name, order, parent)
	local card = Instance.new("Frame")
	card.Name = name
	card.LayoutOrder = order
	card.Size = UDim2.new(0, 156, 0, 60)
	card.BackgroundColor3 = Color3.fromRGB(38, 38, 52)
	card.BackgroundTransparency = 0.92
	card.BorderSizePixel = 0
	card.Parent = parent
	table.insert(ThemeObjects.Backgrounds, card)
	Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)
	local stroke = Instance.new("UIStroke")
	stroke.Name = "ControlOutline"
	stroke.Color = AccentColor
	stroke.Thickness = 1
	stroke.Transparency = 0.75
	stroke.Parent = card
	table.insert(ThemeObjects.Accents, stroke)
	return card
end

