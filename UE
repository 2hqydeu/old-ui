TrackConnection("UndeadExpeditionLightingHeartbeat", RunService.Heartbeat:Connect(function()
	if not uePage.Parent then return end
	local now = os.clock()
	if state.NoDarkness and now - (state.LastLightingApply or 0) >= 1.5 then
		state.LastLightingApply = now
		ApplyNoDarkness()
	end
	if now - (state.LastStructureWatchAt or 0) >= 1 then
		state.LastStructureWatchAt = now
		WatchStructures()
	end
	if state.BoxESP then
		RefreshBoxDistances()
	end
	if state.BoxESP and now - (state.LastBoxScan or 0) >= BOX_SCAN_INTERVAL then
		state.LastBoxScan = now
		UpdateBoxESP()
		RefreshButtons()
	end
	if now - (state.LastESPCategoryScan or 0) >= BOX_SCAN_INTERVAL then
		state.LastESPCategoryScan = now
		UpdateStructuresESP()
		UpdateItemsESP()
		UpdateMobsESP()
	end
	if now - (state.LastGradientPulse or 0) >= 0.033 then
		state.LastGradientPulse = now
		local pulse = 0.5 + ((math.sin((ThemeObjects.GradientPulseTime or 0) * 1.35) + 1) * 0.25)
		ApplyBreathingGradient(filterDockGradient, pulse)
		ApplyBreathingGradient(pickupDockGradient, pulse)
	end
end))

