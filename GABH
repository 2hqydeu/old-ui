local function RefreshHeaderDisplays(force)
	seasonDisplay.Visible = true
	local okTime, now = pcall(function()
		return workspace:GetServerTimeNow()
	end)
	now = okTime and now or os.time()

	local seasonText = FindSeasonTextFallback(force)
	if seasonText then
		seasonDisplay.TextColor3 = ExtractSeasonName(seasonText) and AccentColor or Color3.fromRGB(255, 255, 255)
		seasonDisplay.Text = seasonText
		return
	end

	local seasonMath = GetSeasonMath()
	if seasonMath then
		local okActive, activeSeason = pcall(seasonMath.IsActive, now)
		if okActive and activeSeason then
			local okName, seasonName = pcall(seasonMath.SeasonAt, now)
			local okRemaining, remaining = pcall(seasonMath.ActiveRemaining, now)
			seasonText = ("%s: %s"):format(string.upper(okName and seasonName or "SEASON"), FormatClock(okRemaining and remaining or 0))
			seasonDisplay.TextColor3 = AccentColor
		else
			local okStart, nextStart = pcall(seasonMath.NextSeasonStart, now)
			if okStart and nextStart then
				seasonText = ("SEASON: %s"):format(FormatClock(nextStart - now))
			end
			seasonDisplay.TextColor3 = Color3.fromRGB(255, 255, 255)
		end
	end

	seasonDisplay.Text = seasonText or "SEASON: N/A"
end

