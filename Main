local function RestoreAntiFlingCollisions()
	for part, originalCanCollide in pairs(HubState.AntiFlingOriginalCollision) do
		if part and part.Parent then part.CanCollide = originalCanCollide end
	end
	HubState.AntiFlingOriginalCollision = {}
end

local function RefreshFlingToggle()
	if HubState.FlingToggleBtn then HubState.FlingToggleBtn.Text = HubState.FlingEnabled and "On" or "Off" end
	if ThemeObjects.FlingTargetTitle then ThemeObjects.FlingTargetTitle.TextColor3 = HubState.FlingEnabled and AccentColor or Color3.fromRGB(255, 255, 255) end
end

local function SetIYFling(enabled)
	HubState.FlingEnabled = enabled == true
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not HubState.FlingEnabled then
		if HubState.Connections.IYFlingPulse then
			HubState.Connections.IYFlingPulse:Disconnect()
			HubState.Connections.IYFlingPulse = nil
		end
		if HubState.IYFlingMover and HubState.IYFlingMover.Parent then HubState.IYFlingMover:Destroy() end
		HubState.IYFlingMover = nil
		for part, state in pairs(HubState.FlingOriginalPartStates) do
			if part and part.Parent then
				part.CanCollide = state.CanCollide
				part.Massless = state.Massless
				part.CustomPhysicalProperties = state.CustomPhysicalProperties
			end
		end
		HubState.FlingOriginalPartStates = {}
		if root then
			root.AssemblyAngularVelocity = Vector3.zero
			root.AssemblyLinearVelocity = Vector3.zero
		end
		RefreshFlingToggle()
		return
	end
	if not character or not humanoid or humanoid.Health <= 0 or not root then
		HubState.FlingEnabled = false
		RefreshFlingToggle()
		return
	end
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			if not HubState.FlingOriginalPartStates[part] then
				HubState.FlingOriginalPartStates[part] = {
					CanCollide = part.CanCollide,
					Massless = part.Massless,
					CustomPhysicalProperties = part.CustomPhysicalProperties,
				}
			end
			part.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
			part.CanCollide = false
			part.Massless = true
			part.AssemblyLinearVelocity = Vector3.zero
		end
	end
	if not HubState.IYFlingMover or HubState.IYFlingMover.Parent ~= root then
		if HubState.IYFlingMover and HubState.IYFlingMover.Parent then HubState.IYFlingMover:Destroy() end
		local spin = Instance.new("BodyAngularVelocity")
		spin.Name = "IYFlingSpin"
		spin.AngularVelocity = Vector3.new(0, 99999, 0)
		spin.MaxTorque = Vector3.new(0, math.huge, 0)
		spin.P = math.huge
		spin.Parent = root
		HubState.IYFlingMover = spin
	end
	if HubState.Connections.IYFlingPulse then HubState.Connections.IYFlingPulse:Disconnect() end
	local pulseStart = os.clock()
	HubState.Connections.IYFlingPulse = RunService.Heartbeat:Connect(function()
		local liveCharacter = Player.Character
		local liveHumanoid = liveCharacter and liveCharacter:FindFirstChildOfClass("Humanoid")
		local liveRoot = liveCharacter and liveCharacter:FindFirstChild("HumanoidRootPart")
		if not HubState.FlingEnabled or not liveCharacter or not liveHumanoid or liveHumanoid.Health <= 0 or not liveRoot then
			SetIYFling(false)
			return
		end
		if not HubState.IYFlingMover or HubState.IYFlingMover.Parent ~= liveRoot then
			if HubState.IYFlingMover and HubState.IYFlingMover.Parent then HubState.IYFlingMover:Destroy() end
			local spin = Instance.new("BodyAngularVelocity")
			spin.Name = "IYFlingSpin"
			spin.MaxTorque = Vector3.new(0, math.huge, 0)
			spin.P = math.huge
			spin.Parent = liveRoot
			HubState.IYFlingMover = spin
		end
		local phase = (os.clock() - pulseStart) % 0.3
		HubState.IYFlingMover.AngularVelocity = phase < 0.2 and Vector3.new(0, 99999, 0) or Vector3.zero
	end)
	RefreshFlingToggle()
end

local function FlingPlayer(targetPlayer)
	if HubState.Flinging or not targetPlayer or targetPlayer == Player then return end
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local targetCharacter = targetPlayer.Character
	local targetHumanoid = targetCharacter and targetCharacter:FindFirstChildOfClass("Humanoid")
	local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
	if not humanoid or humanoid.Health <= 0 or not root or not targetHumanoid or targetHumanoid.Health <= 0 or not targetRoot then return end

	HubState.Flinging = true
	local originalCFrame = root.CFrame
	local originalAutoRotate = humanoid.AutoRotate
	local originalAngularVelocity = root.AssemblyAngularVelocity
	local originalLinearVelocity = root.AssemblyLinearVelocity
	local wasFlingEnabled = HubState.FlingEnabled
	humanoid.AutoRotate = false
	RestoreAntiFlingCollisions()
	SetIYFling(true)

	local function cleanup()
		if not wasFlingEnabled then SetIYFling(false) end
		if root and root.Parent then
			root.AssemblyAngularVelocity = originalAngularVelocity
			root.AssemblyLinearVelocity = originalLinearVelocity
			root.CFrame = originalCFrame
		end
		if humanoid and humanoid.Parent then
			humanoid.AutoRotate = originalAutoRotate
		end
		HubState.Flinging = false
	end

	pcall(function()
		local targetContactPart = targetCharacter:FindFirstChild("UpperTorso")
			or targetCharacter:FindFirstChild("Torso")
			or targetCharacter:FindFirstChild("LowerTorso")
			or targetRoot
		local hitOffsets = {
			Vector3.new(0, 0, -0.65),
			Vector3.new(0.65, 0.15, 0),
			Vector3.new(-0.65, 0.15, 0),
			Vector3.new(0, 0.7, -0.25),
			Vector3.new(0, -0.45, -0.25),
			Vector3.new(0, 0, 0.65),
		}
		local startedAt = os.clock()
		local step = 0
		local nextTeleportAt = 0
		local flingSpin = Vector3.new(99999, 99999, 99999)
		while os.clock() - startedAt < 5.0 and targetRoot.Parent and targetHumanoid.Health > 0 and root.Parent and humanoid.Health > 0 do
			character = Player.Character
			humanoid = character and character:FindFirstChildOfClass("Humanoid")
			root = character and character:FindFirstChild("HumanoidRootPart")
			targetCharacter = targetPlayer.Character
			targetHumanoid = targetCharacter and targetCharacter:FindFirstChildOfClass("Humanoid")
			targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
			if not character or not humanoid or humanoid.Health <= 0 or not root or not targetCharacter or not targetHumanoid or targetHumanoid.Health <= 0 or not targetRoot then break end
			targetContactPart = targetCharacter:FindFirstChild("UpperTorso")
				or targetCharacter:FindFirstChild("Torso")
				or targetCharacter:FindFirstChild("LowerTorso")
				or targetRoot
			local targetPosition = targetContactPart.Position + (targetRoot.AssemblyLinearVelocity * 0.12)
			local now = os.clock()
			if now >= nextTeleportAt then
				step += 1
				local offset = hitOffsets[((step - 1) % #hitOffsets) + 1]
				local passPosition = (targetRoot.CFrame * CFrame.new(offset)).Position + (targetRoot.AssemblyLinearVelocity * 0.06)
				root.CFrame = CFrame.new(passPosition, targetPosition) * CFrame.Angles(math.rad(90), 0, 0)
				root.AssemblyLinearVelocity = targetRoot.AssemblyLinearVelocity + Vector3.new(0, 12, 0)
				nextTeleportAt = now + 0.18
			else
				local chaseDirection = targetPosition - root.Position
				if chaseDirection.Magnitude > 0.05 then
					root.AssemblyLinearVelocity = targetRoot.AssemblyLinearVelocity + (chaseDirection.Unit * 34) + Vector3.new(0, 12, 0)
				end
			end
			root.AssemblyAngularVelocity = flingSpin
			if HubState.IYFlingMover and HubState.IYFlingMover.Parent == root then
				HubState.IYFlingMover.AngularVelocity = Vector3.new(0, 99999, 0)
			end
			if os.clock() - startedAt > 0.9 and targetRoot.AssemblyLinearVelocity.Magnitude > 185 then break end
			RunService.Heartbeat:Wait()
		end
	end)
	cleanup()
end

local function RefreshFlingTargets()
	for _, child in ipairs(HubState.TargetScroll:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end

	local filter = HubState.TargetSearch.Text:lower()
	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		if targetPlayer ~= Player then
			local displayText = targetPlayer.DisplayName or targetPlayer.Name
			if filter == "" or displayText:lower():find(filter, 1, true) or targetPlayer.Name:lower():find(filter, 1, true) then
				local targetRow = Instance.new("Frame")
				targetRow.Name = "TargetRow"
				targetRow.Size = UDim2.new(1, 0, 0, 30)
				targetRow.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
				targetRow.BackgroundTransparency = 0.8
				targetRow.BorderSizePixel = 0
				targetRow.Parent = HubState.TargetScroll
				Instance.new("UICorner", targetRow).CornerRadius = UDim.new(0, 4)
				ThemeObjects.StyleControlOutline(targetRow)

				local displayLabel = Instance.new("TextLabel")
				displayLabel.Size = UDim2.new(1, -12, 0, 16)
				displayLabel.Position = UDim2.new(0, 7, 0, 1)
				displayLabel.BackgroundTransparency = 1
				displayLabel.Text = displayText
				displayLabel.Font = Enum.Font.GothamBold
				displayLabel.TextSize = 10
				displayLabel.TextXAlignment = Enum.TextXAlignment.Left
				displayLabel.Parent = targetRow
				table.insert(ThemeObjects.Texts, displayLabel)

				local usernameLabel = Instance.new("TextLabel")
				usernameLabel.Size = UDim2.new(1, -12, 0, 11)
				usernameLabel.Position = UDim2.new(0, 7, 0, 16)
				usernameLabel.BackgroundTransparency = 1
				usernameLabel.Text = "@" .. targetPlayer.Name
				usernameLabel.Font = Enum.Font.GothamBold
				usernameLabel.TextSize = 8
				usernameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
				usernameLabel.TextTransparency = 0
				usernameLabel.TextXAlignment = Enum.TextXAlignment.Left
				usernameLabel.Parent = targetRow
				table.insert(ThemeObjects.Texts, usernameLabel)

				local targetButton = Instance.new("TextButton")
				targetButton.Size = UDim2.new(1, 0, 1, 0)
				targetButton.BackgroundTransparency = 1
				targetButton.Text = ""
				targetButton.Parent = targetRow
				targetButton.MouseButton1Click:Connect(function()
					PlayClick()
					task.spawn(FlingPlayer, targetPlayer)
				end)
			end
		end
	end
	HubState.TargetScroll.CanvasSize = UDim2.new(0, 0, 0, HubState.TargetListLayout.AbsoluteContentSize.Y + 2)
	UpdateTheme()
end

HubState.TargetSearch:GetPropertyChangedSignal("Text"):Connect(RefreshFlingTargets)
TrackConnection("FlingTargetsPlayerAdded", Players.PlayerAdded:Connect(RefreshFlingTargets))
TrackConnection("FlingTargetsPlayerRemoving", Players.PlayerRemoving:Connect(RefreshFlingTargets))

local function ToggleFlingMenu()
	PlaySwoosh()
	if not HubState.TargetFrame.Visible then RefreshFlingTargets() end
	HubState.TargetFrame.Visible = not HubState.TargetFrame.Visible
end
ThemeObjects.AddFeatureKeybind({Name = "Fling Target", Category = "Main Features", Storage = "FlingTarget", Button = HubState.FlingBindBtn, Get = function() return HubState.FlingTargetKeybind end, Set = function(key) HubState.FlingTargetKeybind = key; SaveKeybind("FlingTarget", key); if HubState.FlingBindBtn then HubState.FlingBindBtn.Text = KeybindText(key) end end, Action = ToggleFlingMenu})
ThemeObjects.AddFeatureKeybind({Name = "Fling", Category = "Main Features", Storage = "Fling", Parent = HubState.FlingToggleBtn and HubState.FlingToggleBtn.Parent, Toggle = HubState.FlingToggleBtn, Get = function() return HubState.FlingKeybind end, Set = function(key) HubState.FlingKeybind = key; SaveKeybind("Fling", key) end, Action = function()
	SetIYFling(not HubState.FlingEnabled)
end})

HubState.FlingTargetBtn.MouseButton1Click:Connect(function() PlayClick() ToggleFlingMenu() end)
HubState.FlingToggleBtn.MouseButton1Click:Connect(function()
	PlayClick()
	SetIYFling(not HubState.FlingEnabled)
end)

