-- LATEST_FIXED_2026_06_29: notification, scrollbar, waypoint text, and input layout fixes applied.
-- Services
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local Lighting = game:GetService("Lighting")
local ContextActionService = game:GetService("ContextActionService")
local TeleportService = game:GetService("TeleportService")

local Player = Players.LocalPlayer
local InterfaceScale = 1.18
local ScriptStartTime = os.clock()

local KeybindStorageFile = "HqydeuLoader_Keybinds.json"
local SavedKeybinds = {}
local CanPersistKeybinds = type(isfile) == "function" and type(readfile) == "function" and type(writefile) == "function"
local function LoadSettingsFromGenv()
	if type(getgenv) == "function" then
		local globalSettings = getgenv().HqydeuLoader_Settings
		if type(globalSettings) == "table" then SavedKeybinds = globalSettings end
	end
end

-- Checked both before and after the file-based load: a prior session in the
-- same executor context may already hold newer settings than what's on disk.
LoadSettingsFromGenv()

if CanPersistKeybinds then
	pcall(function()
		if isfile(KeybindStorageFile) then
			local decoded = HttpService:JSONDecode(readfile(KeybindStorageFile))
			if type(decoded) == "table" then SavedKeybinds = decoded end
		end
	end)
end
LoadSettingsFromGenv()

local GuiSizeValue = math.clamp(tonumber(SavedKeybinds.GuiSize) or 50, 20, 100)
local function GuiScaleFromValue(value)
	return InterfaceScale * (value / 50)
end

local BackgroundTransparencyValue = math.clamp(tonumber(SavedKeybinds.BackgroundTransparency) or 0, 0, 100)

SavedKeybinds.KeybindsByPlace = type(SavedKeybinds.KeybindsByPlace) == "table" and SavedKeybinds.KeybindsByPlace or {}
local KeybindScopeActive = false
local KeybindScopePlaceKey = nil
local KeybindScopeName = nil
local SuppressScopedKeybindSave = false

local function DecodeKeybind(savedName)
	if type(savedName) == "string" then
		local success, keyCode = pcall(function() return Enum.KeyCode[savedName] end)
		if success and keyCode then return keyCode end
	end
	return nil
end

local function LoadKeybind(featureName)
	if KeybindScopeActive then
		local bucket = SavedKeybinds.KeybindsByPlace[KeybindScopePlaceKey or tostring(game.PlaceId)]
		local scopedKey = type(bucket) == "table" and DecodeKeybind(bucket[featureName]) or nil
		if scopedKey then return scopedKey end
	end
	return DecodeKeybind(SavedKeybinds[featureName]) or Enum.KeyCode.Unknown
end

-- MinimizeGUI defaults to Left Control on a fresh save file. SavedKeybinds.MinimizeGUI
-- only stays nil before the player has ever set (or explicitly cleared) this bind, so
-- checking the raw saved value (rather than the decoded result) lets a deliberate clear
-- stick instead of reverting to the default on the next load/scope change.
local function LoadMinimizeKeybind()
	if SavedKeybinds.MinimizeGUI == nil then
		return Enum.KeyCode.LeftControl
	end
	return LoadKeybind("MinimizeGUI")
end

local function SavePersistentSettings()
	if type(getgenv) == "function" then
		getgenv().HqydeuLoader_Settings = SavedKeybinds
	end
	if CanPersistKeybinds then
		pcall(function() writefile(KeybindStorageFile, HttpService:JSONEncode(SavedKeybinds)) end)
	end
end

local function SaveKeybind(featureName, keyCode)
	if SuppressScopedKeybindSave then return end
	if KeybindScopeActive then
		local placeKey = KeybindScopePlaceKey or tostring(game.PlaceId)
		local bucket = SavedKeybinds.KeybindsByPlace[placeKey]
		if type(bucket) ~= "table" then
			bucket = {}
			SavedKeybinds.KeybindsByPlace[placeKey] = bucket
		end
		bucket[featureName] = keyCode.Name
	else
		SavedKeybinds[featureName] = keyCode.Name
	end
	SavePersistentSettings()
end

local function CurrentPlaceKeybindBucket()
	local placeKey = KeybindScopePlaceKey or tostring(game.PlaceId)
	local bucket = SavedKeybinds.KeybindsByPlace[placeKey]
	if type(bucket) ~= "table" then
		bucket = {}
		SavedKeybinds.KeybindsByPlace[placeKey] = bucket
	end
	return bucket
end

local function LoadGameKeybind(featureName)
	local bucket = SavedKeybinds.KeybindsByPlace[KeybindScopePlaceKey or tostring(game.PlaceId)]
	local savedName = type(bucket) == "table" and bucket[featureName] or nil
	local keyCode = DecodeKeybind(savedName)
	if keyCode then return keyCode end
	return LoadKeybind(featureName)
end

local function SaveGameKeybind(featureName, keyCode)
	if SuppressScopedKeybindSave then return end
	CurrentPlaceKeybindBucket()[featureName] = keyCode.Name
	SavePersistentSettings()
end

local function LoadColor(settingName, fallback)
	local saved = SavedKeybinds[settingName]
	if type(saved) == "table" and tonumber(saved.R) and tonumber(saved.G) and tonumber(saved.B) then
		return Color3.fromRGB(saved.R, saved.G, saved.B)
	end
	return fallback
end

local function PackColor(color)
	return {
		R = math.floor(color.R * 255 + 0.5),
		G = math.floor(color.G * 255 + 0.5),
		B = math.floor(color.B * 255 + 0.5),
	}
end

local function UnpackColor(saved, fallback)
	if type(saved) == "table" and tonumber(saved.R) and tonumber(saved.G) and tonumber(saved.B) then
		return Color3.fromRGB(saved.R, saved.G, saved.B)
	end
	return fallback
end

local DefaultFrameColor = Color3.fromRGB(28, 28, 38)
local DefaultAccentColor = Color3.fromRGB(255, 255, 255)
local FrameThemeColor = LoadColor("ThemeFrame", DefaultFrameColor)
local AccentColor = LoadColor("ThemeAccent", DefaultAccentColor)

local function SaveThemeColors()
	SavedKeybinds.ThemeFrame = PackColor(FrameThemeColor)
	SavedKeybinds.ThemeAccent = PackColor(AccentColor)
	SavePersistentSettings()
end

local function KeybindText(keyCode)
	if keyCode == Enum.KeyCode.Unknown then return "..." end
	if keyCode == Enum.KeyCode.LeftControl then return "L Ctrl" end
	if keyCode == Enum.KeyCode.RightControl then return "R Ctrl" end
	return keyCode.Name
end

