local function SafeRequire(pathParts)
	local current = game
	for index, part in ipairs(pathParts) do
		if index == 1 and (part == "ReplicatedStorage" or part == "Players" or part == "Workspace") then
			current = game:GetService(part == "Workspace" and "Workspace" or part)
		else
			current = current and current:FindFirstChild(part)
		end
		if not current then return nil end
	end
	local ok, result = pcall(require, current)
	return ok and result or nil
end

local function GetSeasonMath()
	if seasonMathCache ~= nil and seasonMathCache ~= false then return seasonMathCache end
	if seasonMathCache == false and os.clock() - (state.LastSeasonMathRequire or 0) < 3 then return nil end
	state.LastSeasonMathRequire = os.clock()
	seasonMathCache = SafeRequire({"ReplicatedStorage", "Modules", "SeasonMath"}) or false
	return seasonMathCache ~= false and seasonMathCache or nil
end

local function GetBeeConfig()
	if beeConfigCache ~= nil and beeConfigCache ~= false then return beeConfigCache end
	if beeConfigCache == false and os.clock() - (state.LastBeeConfigRequire or 0) < 3 then return nil end
	state.LastBeeConfigRequire = os.clock()
	beeConfigCache = SafeRequire({"ReplicatedStorage", "Configs", "BeeConfig"}) or false
	return beeConfigCache ~= false and beeConfigCache or nil
end

local function GetRarityConfig()
	if rarityConfigCache ~= nil and rarityConfigCache ~= false then return rarityConfigCache end
	if rarityConfigCache == false and os.clock() - (state.LastRarityConfigRequire or 0) < 3 then return nil end
	state.LastRarityConfigRequire = os.clock()
